---
import Button from "@components/Button/Button.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<form id="contact-form" name="contact" method="POST" action={lang === 'fr' ? '/merci/' : '/en/thank-you/'} netlify netlify-honeypot="bot-field" data-astro-reload class="flex h-full flex-col justify-between gap-4">
	<p class="hidden">
		<label>
			Ne pas remplir si vous êtes humain : <input name="bot-field" />
		</label>
	</p>
	<input type="hidden" name="form-name" value="contact" />
	<div>
		<label for="contact-name" class="font-heading-1 text-lg uppercase">{t('form.name')}</label>
		<input type="text" class="form__input" name="name" id="contact-name" placeholder="" required />
	</div>
	<div class="flex flex-col gap-1">
		<label for="contact-email" class="font-heading-1 text-lg uppercase">{t('form.email')}</label>
		<input
			type="email"
			class="form__input"
			name="email"
			id="contact-email"
			inputmode="email"
			placeholder=""
			required
		/>
	</div>
	<div class="flex flex-col gap-1">
		<label for="contact-whatsapp" class="font-heading-1 text-lg uppercase">{t('form.whatsapp')}</label>
		<div class="flex gap-2">
			<select name="country-code" class="form__input w-32 shrink-0 cursor-pointer" aria-label="Code pays">
				<option value="+33" selected>+33 (FR)</option>
				<option value="+52">+52 (MX)</option>
				<option value="+1">+1 (US/CA)</option>
				<option value="+34">+34 (ES)</option>
				<option value="+41">+41 (CH)</option>
				<option value="+32">+32 (BE)</option>
				<option value="+44">+44 (UK)</option>
			</select>
			<input
				type="tel"
				class="form__input"
				name="whatsapp"
				id="contact-whatsapp"
				inputmode="tel"
				placeholder=""
			/>
		</div>
	</div>
	<div>
		<label for="contact-message" class="font-heading-1 text-lg uppercase">{t('form.message')}</label>
		<textarea
			name="message"
			class="form__input"
			id="contact-message"
			rows="6"
			placeholder=""
			required></textarea>
	</div>
	<div class="flex justify-start">
		<Button variant="primary" type="submit" class="w-full px-10 md:w-fit">{t('form.submit')}</Button>
	</div>
</form>
