---
// main layout
// components
import Button from "@components/Button/Button.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Thank you!" description="Your message has been sent successfully." noindex={true}>
	<section class="site-container pt-36 text-center md:pt-44">
		<div class="mx-auto max-w-xl px-4 text-center">
			<h1 class="h1">Thank you!</h1>
			<p class="description mt-4 text-lg">
				Your message has been sent successfully. I will get back to you as soon as possible!
			</p>
			<div class="mt-8 flex justify-center">
				<Button variant="primary" href="/en/">Return to homepage</Button>
			</div>
		</div>
	</section>
</BaseLayout>
