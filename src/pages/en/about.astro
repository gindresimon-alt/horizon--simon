---
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/Button/Button.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { Image } from "astro:assets";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const title = t('about.page.title') + " | Simon Gindre";
const description = t('about.page.desc');

// images
---

<BaseLayout {title} {description} navStartStyle="white">
	{/* 1. Intro Section */}
	<section class="site-container py-24 md:py-32">
		<div class="mx-auto max-w-4xl text-center">
			<p class="text-primary-600 font-bold tracking-widest uppercase mb-4">{t('about.intro.p1')}</p>
			<h1 class="h1 mb-8">{t('about.intro.p2')}</h1>
			<p class="text-xl text-base-600 leading-relaxed md:text-2xl whitespace-pre-line max-w-2xl mx-auto">
				{t('about.intro.p3')}
			</p>
		</div>
	</section>

	{/* 2. Identity Section */}
	<section class="bg-base-50 py-20 md:py-32">
		<div class="site-container">
			<div class="mx-auto max-w-3xl text-center">
				<h2 class="h2 mb-8">{t('about.identity.title')}</h2>
				<p class="text-lg leading-relaxed lg:text-xl">
					{t('about.identity.content')}
				</p>
			</div>
		</div>
	</section>

	{/* 3. Journey - Travel as Revelation */}
	<section class="site-container py-20 md:py-32 border-b border-base-100">
		<div class="mx-auto max-w-3xl text-center">
			<h2 class="h3 mb-8 text-primary-600 uppercase tracking-tight">{t('about.journey.title')}</h2>
			<div class="space-y-6 text-lg leading-relaxed text-base-800">
				<p>{t('about.journey.p1')}</p>
				<p class="whitespace-pre-line">{t('about.journey.p2')}</p>
				<p>{t('about.journey.p3')}</p>
				<p class="italic text-base-500">{t('about.journey.p4')}</p>
			</div>
		</div>
	</section>

	{/* 4. Exploration - World and Nature */}
	<section class="bg-base-900 text-white py-20 md:py-32">
		<div class="site-container">
				<div class="space-y-8 text-lg md:text-xl font-light opacity-90 leading-relaxed">
					<div class="pt-8">
						<p class="font-bold text-primary-400 whitespace-pre-line mb-4">{t('about.exploration.p4')}</p>
						<p class="whitespace-pre-line">{t('about.exploration.p5')}</p>
					</div>
				</div>
			</div>
		</div>
	</section>


	{/* 6. Vision of Accompaniment */}
	<section class="bg-base-50 py-20 md:py-32">
		<div class="site-container flex flex-col items-center">
			<h2 class="h2 mb-12 text-center uppercase tracking-tight">{t('about.vision.title')}</h2>
			<div class="mx-auto max-w-3xl text-center mb-16 space-y-8">
				<div class="space-y-2">
					<p class="text-base-500 uppercase tracking-widest text-sm">{t('about.vision.p1')}</p>
					<p class="text-3xl font-serif md:text-4xl text-base-900">{t('about.vision.p2')}</p>
				</div>
				<p class="text-lg whitespace-pre-line">{t('about.vision.p3')}</p>
				<p class="text-lg font-bold">{t('about.vision.p4')}</p>
			</div>

			<div class="bg-white p-12 shadow-xl rounded-sm max-w-2xl w-full border border-base-100">
				<h3 class="h4 mb-8 text-primary-600 border-b pb-4">{t('about.vision.list_title')}</h3>
				<ul class="space-y-4 text-lg mb-8">
					<li class="flex items-start gap-3">
						<span class="text-primary-500 font-bold">—</span>
						{t('about.vision.item1')}
					</li>
					<li class="flex items-start gap-3">
						<span class="text-primary-500 font-bold">—</span>
						{t('about.vision.item2')}
					</li>
					<li class="flex items-start gap-3">
						<span class="text-primary-500 font-bold">—</span>
						{t('about.vision.item3')}
					</li>
					<li class="flex items-start gap-3">
						<span class="text-primary-500 font-bold">—</span>
						{t('about.vision.item4')}
					</li>
				</ul>
				<p class="text-sm text-base-500 italic whitespace-pre-line">
					{t('about.vision.footer')}
				</p>
			</div>
		</div>
	</section>

	{/* 7. Playa Context */}
	<section class="site-container py-20 md:py-32">
		<div class="mx-auto max-w-3xl">
			<h2 class="h2 mb-12 text-center">{t('about.playa.title')}</h2>
			<div class="space-y-6 text-lg leading-relaxed">
				<p>{t('about.playa.p1')}</p>
				<ul class="space-y-4">
					{t('about.playa.p2').split('\n').filter((line: string) => line.trim() !== '').map((line: string) => (
						<li>{line}</li>
					))}
				</ul>
				<p class="font-light italic text-base-400">{t('about.playa.p3')}</p>
				<p class="text-xl font-medium pt-4 text-primary-700">{t('about.playa.p4')}</p>
			</div>
		</div>
	</section>

	{/* 8. The Proposal */}
	<section class="bg-primary-900 text-white py-20 md:py-32">
		<div class="site-container">
			<div class="mx-auto max-w-4xl">
				<h2 class="h2 mb-16 text-center">{t('about.proposal.title')}</h2>
				<div class="grid gap-8 md:grid-cols-3 text-center mb-16">
					<div class="p-8 border border-white/10 bg-white/5 rounded-sm">
						<p class="text-xl font-bold uppercase tracking-tight">{t('about.proposal.item1')}</p>
					</div>
					<div class="p-8 border border-white/10 bg-white/5 rounded-sm">
						<p class="text-xl font-bold uppercase tracking-tight">{t('about.proposal.item2')}</p>
					</div>
					<div class="p-8 border border-white/10 bg-white/5 rounded-sm">
						<p class="text-xl font-bold uppercase tracking-tight">{t('about.proposal.item3')}</p>
					</div>
				</div>
				<p class="text-center text-lg md:text-xl font-light opacity-80 max-w-2xl mx-auto">
					{t('about.proposal.footer')}
				</p>
			</div>
		</div>
	</section>

	{/* 9. Final CTA */}
	<section class="site-container py-24 md:py-32 text-center">
		<div class="mx-auto max-w-3xl">
			<h2 class="h2 mb-8">{t('about.conclusion.title')}</h2>
			<p class="text-2xl mb-12 font-serif italic text-base-600 tracking-tight">{t('about.conclusion.p1')}</p>
			<Button variant="primary" href={lang === 'fr' ? "/contact/" : "/en/contact/"}>
				{t('therapie.contact_cta.button')}
			</Button>
		</div>
	</section>
</BaseLayout>

