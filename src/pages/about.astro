---
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/Button/Button.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { Image } from "astro:assets";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const title = t('about.page.title') + " | Simon Gindre";
const description = t('about.page.desc');

// images
---

<BaseLayout {title} {description} navStartStyle="white">
	{/* 1. Intro Section */}
	<section class="site-container py-24 md:py-32 border-b border-base-100">
		<div class="mx-auto max-w-4xl text-center">
			<p class="text-primary-600 font-bold tracking-widest uppercase mb-4 italic">{t('about.intro.p1')}</p>
			<h1 class="h1 mb-8 text-base-900 leading-tight">{t('about.intro.p2')}</h1>
			<p class="text-xl text-base-600 leading-relaxed md:text-2xl whitespace-pre-line max-w-2xl mx-auto italic font-serif opacity-80">
				{t('about.intro.p3')}
			</p>
		</div>
	</section>

	{/* 2. Identity Section */}
	<section class="bg-base-50 py-20 md:py-32 border-b border-base-100">
		<div class="site-container">
			<div class="mx-auto max-w-3xl text-center">
				<h2 class="h2 mb-8">{t('about.identity.title')}</h2>
				<p class="text-lg leading-relaxed lg:text-xl whitespace-pre-line">
					{t('about.identity.content')}
				</p>
			</div>
		</div>
	</section>

	{/* 3. Journey - Travel as Revelation */}
	<section class="site-container py-20 md:py-32 border-b border-base-100">
		<div class="mx-auto max-w-3xl text-center">
			<h2 class="h3 mb-8 text-primary-600 uppercase tracking-tight">{t('about.journey.title')}</h2>
			<div class="space-y-6 text-lg leading-relaxed text-base-800">
				<p>{t('about.journey.p1')}</p>
				<p>{t('about.journey.p2')}</p>
				<p>{t('about.journey.p3')}</p>
				<div class="pt-6 border-t border-base-100 space-y-4">
					<p class="whitespace-pre-line italic font-serif text-primary-800">{t('about.journey.p4')}</p>
				</div>
			</div>
		</div>
	</section>

	{/* 4. Exploration - World and Nature */}
	<section class="bg-base-900 text-white py-20 md:py-32">
		<div class="site-container">
			<div class="mx-auto max-w-3xl">
				<div class="space-y-8 text-lg md:text-xl font-light opacity-90 leading-relaxed">
					<div class="pt-8">
						<p class="font-bold text-primary-400 whitespace-pre-line mb-6 font-serif text-2xl md:text-3xl leading-snug">{t('about.exploration.p4')}</p>
						<p class="whitespace-pre-line opacity-80">{t('about.exploration.p5')}</p>
					</div>
				</div>
			</div>
		</div>
	</section>


	{/* 6. Vision of Accompaniment */}
	<section class="bg-base-50 py-20 md:py-32 border-b border-base-100">
		<div class="site-container flex flex-col items-center">
			<h2 class="h2 mb-12 text-center uppercase tracking-tight">{t('about.vision.title')}</h2>
			<div class="mx-auto max-w-3xl text-center mb-16">
				<p class="text-2xl font-serif md:text-3xl text-base-900 italic tracking-tight">{t('about.vision.p1')}</p>
			</div>

			<div class="bg-white p-12 shadow-xl rounded-sm max-w-2xl w-full border border-base-100">
				<h3 class="h4 mb-8 text-primary-600 border-b pb-4 uppercase tracking-wider">{t('about.vision.list_title')}</h3>
				<ul class="space-y-4 text-lg mb-10">
					<li class="flex items-start gap-3">
						<span class="text-primary-500 font-bold">—</span>
						{t('about.vision.item1')}
					</li>
					<li class="flex items-start gap-3">
						<span class="text-primary-500 font-bold">—</span>
						{t('about.vision.item2')}
					</li>
					<li class="flex items-start gap-3">
						<span class="text-primary-500 font-bold">—</span>
						{t('about.vision.item3')}
					</li>
					<li class="flex items-start gap-3">
						<span class="text-primary-500 font-bold">—</span>
						{t('about.vision.item4')}
					</li>
				</ul>
				<div class="bg-primary-50/50 p-6 rounded-sm border-l-4 border-primary-200">
					<p class="text-base text-base-700 font-serif italic leading-relaxed whitespace-pre-line">
						{t('about.vision.footer')}
					</p>
				</div>
			</div>
		</div>
	</section>

	{/* 7. Who for? */}
	<section class="site-container py-20 md:py-32 border-b border-base-100">
		<div class="mx-auto max-w-3xl">
			<h3 class="h2 text-center mb-12 text-base-400 tracking-tighter uppercase">{t('about.playa.title')}</h3>
			<p class="text-center text-xl mb-12 font-medium">{t('about.playa.p1')}</p>
			<div class="grid gap-6 text-lg leading-relaxed text-base-700 bg-base-50 p-10 rounded-sm border md:grid-cols-2">
				<ul class="space-y-4">
					{t('about.playa.p2').split('\n').filter((line: string) => line.trim() !== '').map((line: string) => (
						<li>{line}</li>
					))}
				</ul>
			</div>
		</div>
	</section>

	{/* 8. Playa Context */}
	<section class="site-container py-20 md:py-32 border-b border-base-100">
		<div class="mx-auto max-w-3xl">
			<h2 class="h2 mb-12 text-center uppercase tracking-tight">{t('about.playa.title2')}</h2>
			<div class="space-y-8 text-lg leading-relaxed text-center">
				<p class="text-xl md:text-2xl font-light">{t('about.playa.p3')}</p>
				<p class="text-xl font-medium italic text-primary-700 max-w-2xl mx-auto">
					{t('about.playa.p4')}
				</p>
			</div>
		</div>
	</section>

	{/* 9. Final CTA */}
	<section class="bg-primary-50 py-24 md:py-32 text-center">
		<div class="site-container">
			<div class="mx-auto max-w-3xl">
				<h2 class="h2 mb-8">{t('about.conclusion.title')}</h2>
				<p class="text-2xl mb-4 font-serif italic text-base-900 tracking-tight">{t('about.conclusion.p1')}</p>
				<p class="text-lg text-base-600 mb-12 max-w-xl mx-auto italic font-serif">
					“{t('about.conclusion.p2')}”
				</p>
				<Button variant="primary" href={lang === 'fr' ? "/contact/" : "/en/contact/"}>
					{t('therapie.contact_cta.button')}
				</Button>
			</div>
		</div>
	</section>
</BaseLayout>

